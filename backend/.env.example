PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# Shared-secret key clients must send as the x-api-key header
API_KEY=

# Comma-separated list of origins allowed to call this API from a browser.
# Leave unset to allow all origins (fine for server-to-server use).
ALLOWED_ORIGINS=https://yourfrontend.com



# Firebase Realtime Database
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
# Local dev: point at a downloaded service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Cloud deploys: paste the ENTIRE service account JSON as one line instead
# (takes priority over FIREBASE_SERVICE_ACCOUNT_PATH if both are set)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# JazzCash Merchant (Mobile Wallet / Mobile Account API)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=https://yourapp.com/api/payment/callback
# Sandbox endpoint shown below - switch to production URL when going live
JAZZCASH_API_URL=https://sandbox.jazzcash.com.pk/ApplicationAPI/API/Payment/DoMWalletTransaction

# Business rules
MAX_FILE_SIZE_MB=30
PRICE_PER_PAGE_PKR=10
